# ── Data paths ────────────────────────────────────────────────────────────────
# Absolute path to your Chroma DB folder (default: ./data/chroma_db)
CHROMA_DB_PATH=./data/chroma_db

# Absolute path to your knowledge graph JSON (default: ./data/knowledge_graph.json)
KNOWLEDGE_GRAPH_PATH=./data/knowledge_graph.json

# Directory where case history JSON files are stored
CASE_HISTORY_DIR=./data/case_history

# SQLite database file (created automatically on first run)
DATABASE_PATH=./data/police_bot.db

# ── LLM backend ───────────────────────────────────────────────────────────────
# Choose "ollama" for local inference or "huggingface" for cloud (Render/Vercel)
LLM_BACKEND=ollama

# ── Ollama (local development) ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# For Render free tier (lightweight, ~600 MB, fast startup):
OLLAMA_MODEL=tinyllama
# For local dev with more RAM (better quality responses):
# OLLAMA_MODEL=mistral

# ── Hugging Face (cloud deployment) ──────────────────────────────────────────
# Get your free token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ── JWT authentication ────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Development mode ──────────────────────────────────────────────────────────
# When true, authentication is optional (no token = dev user).
# Set to "false" in production!
DEV_MODE=true

# ── Chroma ────────────────────────────────────────────────────────────────────
CHROMA_COLLECTION_NAME=ndps_documents

# ── RAG tuning ────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.3

# ── Server ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/police_bot.log
