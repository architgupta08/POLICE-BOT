# ── Data paths ────────────────────────────────────────────────────────────────
# Absolute path to your Chroma DB folder (default: ./data/chroma_db)
CHROMA_DB_PATH=./data/chroma_db

# Absolute path to your knowledge graph JSON (default: ./data/knowledge_graph.json)
KNOWLEDGE_GRAPH_PATH=./data/knowledge_graph.json

# Directory where case history JSON files are stored
CASE_HISTORY_DIR=./data/case_history

# ── Ollama / LLM ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Recommended for 8 GB RAM: mistral (7B)
# With 16 GB RAM you can try: llama2:13b
OLLAMA_MODEL=mistral

# ── Chroma ────────────────────────────────────────────────────────────────────
CHROMA_COLLECTION_NAME=ndps_documents

# ── RAG tuning ────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.3

# ── Server ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/police_bot.log
